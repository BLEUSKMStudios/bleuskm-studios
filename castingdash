<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Casting Dashboard — BLEUSKM Studios</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="castingdash.css" />
</head>
<body>

  <!-- Header -->
  <header class="dash-header">
    <div class="header-inner">
      <div class="header-left">
        <span class="studio-label">BLEUSKM STUDIOS</span>
        <span class="header-divider"></span>
        <span class="page-label">CASTING DASHBOARD</span>
      </div>
      <div class="header-right">
        <span class="record-count" id="recordCount">— submissions</span>
        <button class="refresh-btn" id="refreshBtn" title="Refresh data">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.5 7A5.5 5.5 0 1 1 7 1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M7 1.5L9.5 4M7 1.5L9.5 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Refresh
        </button>
      </div>
    </div>
    <div class="header-rule"></div>
  </header>

  <!-- Main -->
  <main class="dash-main">

    <!-- Filter bar -->
    <div class="filter-bar">
      <div class="filter-group">
        <button class="filter-btn active" data-filter="All">All</button>
        <button class="filter-btn" data-filter="Callback">Callback</button>
        <button class="filter-btn" data-filter="Redirect">Redirect</button>
        <button class="filter-btn" data-filter="Rejected">Rejected</button>
      </div>
      <div class="filter-meta">
        <span class="filter-tally" id="filterTally"></span>
      </div>
    </div>

    <!-- State: loading -->
    <div class="state-panel" id="stateLoading">
      <div class="loader-ring"></div>
      <p class="state-text">Loading submissions…</p>
    </div>

    <!-- State: error -->
    <div class="state-panel hidden" id="stateError">
      <p class="state-icon">✕</p>
      <p class="state-text" id="stateErrorMsg">Could not load submissions.</p>
      <button class="ghost-btn" onclick="loadSubmissions()">Try again</button>
    </div>

    <!-- State: empty -->
    <div class="state-panel hidden" id="stateEmpty">
      <p class="state-text">No submissions match this filter.</p>
    </div>

    <!-- Table -->
    <div class="table-wrap hidden" id="tableWrap">
      <table class="casting-table" id="castingTable">
        <thead>
          <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="castingTableBody"></tbody>
      </table>
    </div>

  </main>

  <!-- Toast -->
  <div class="toast-stack" id="toastStack"></div>

  <script src="castingdash.js"></script>
</body>
</html>
